#include <Servo.h>

// ----------- Servo Objects -----------
Servo leg1;
Servo leg2;
Servo leg3;
Servo leg4;
Servo tail;

// ----------- Ultrasonic Pins -----------
#define trigPin 10
#define echoPin 11

long duration;
int distance;

// ----------- Setup -----------
void setup() {
  // Attach Servos (change pins if needed)
  leg1.attach(3);
  leg2.attach(5);
  leg3.attach(6);
  leg4.attach(9);
  tail.attach(8);

  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);

  Serial.begin(9600);
}

// ----------- Read Distance -----------
int getDistance() {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  duration = pulseIn(echoPin, HIGH);
  distance = duration * 0.034 / 2;

  return distance;
}

// ----------- Basic Movements -----------

// Neutral Position
void stand() {
  leg1.write(90);
  leg2.write(90);
  leg3.write(90);
  leg4.write(90);
}

// Move Forward (simple gait)
void moveForward() {
  leg1.write(70);
  leg2.write(110);
  leg3.write(70);
  leg4.write(110);
  delay(300);

  leg1.write(110);
  leg2.write(70);
  leg3.write(110);
  leg4.write(70);
  delay(300);
}

// Move Backward
void moveBackward() {
  leg1.write(110);
  leg2.write(70);
  leg3.write(110);
  leg4.write(70);
  delay(300);

  leg1.write(70);
  leg2.write(110);
  leg3.write(70);
  leg4.write(110);
  delay(300);
}

// Stop Movement
void stopMove() {
  stand();
}

// ----------- Tail Function -----------
void wagTail() {
  for (int i = 0; i < 3; i++) {
    tail.write(60);
    delay(200);
    tail.write(120);
    delay(200);
  }
  tail.write(90); // center
}

// ----------- Loop -----------
void loop() {
  distance = getDistance();

  Serial.print("Distance: ");
  Serial.println(distance);

  if (distance > 0 && distance < 20) {
    stopMove();
    wagTail();        // React to object
    moveBackward();   // Optional: move back
  } 
  else {
    moveForward();    // Normal movement
  }
}
